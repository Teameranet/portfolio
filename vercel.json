{
  "buildCommand": "npm rebuild && npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm ci",
  "headers": [
    {
      "source": "/Ashwin UI-UX Designer & Developer.pdf",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "inline; filename=\"Ashwin UI-UX Designer & Developer.pdf\"; filename*=UTF-8''Ashwin%20UI-UX%20Designer%20%26%20Developer.pdf" }
      ]
    },
    {
      "source": "/download-resume",
      "headers": [
        { "key": "Content-Type", "value": "application/pdf" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"Ashwin UI-UX Designer & Developer.pdf\"; filename*=UTF-8''Ashwin%20UI-UX%20Designer%20%26%20Developer.pdf" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/download-resume", "destination": "/Ashwin UI-UX Designer & Developer.pdf" },
    { "source": "/((?!.*\\.(pdf|html)$).*)", "destination": "/index.html" }
  ]
}
